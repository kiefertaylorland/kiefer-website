---
interface Props {
  title: string;
  date: Date;
  description: string;
  slug: string;
}

const { title, date, description, slug } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card">
  <a href={`/blog/${slug}/`} class="post-card-link">
    <h3>{title}</h3>
    <time datetime={date.toISOString()}>{formattedDate}</time>
    <p>{description}</p>
    <span class="post-card-cta" aria-hidden="true">Read post</span>
  </a>
</article>
