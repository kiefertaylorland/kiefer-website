---
const base = '/kiefer-website';
const navLinks = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/blog/`, label: 'Blog' },
  { href: `${base}/about/`, label: 'About' },
];
---

<header class="header">
  <div class="header-inner">
    <a href={`${base}/`} class="site-title">Kiefer.dev</a>
    <nav class="nav">
      {navLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
  </div>
</header>
