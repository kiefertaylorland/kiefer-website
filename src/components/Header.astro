---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog/', label: 'Blog' },
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
];
---

<header class="header">
  <div class="header-inner">
    <a href="/" class="site-title" aria-label="Home">Kiefer Taylor Land</a>
    <nav class="nav">
      {navLinks.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
      <button id="theme-toggle" class="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
        🌙
      </button>
    </nav>
  </div>
</header>

<style>
  .theme-toggle {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.1rem;
    padding: 0.25rem;
    line-height: 1;
    opacity: 0.7;
    transition: opacity 0.15s ease;
  }
  .theme-toggle:hover {
    opacity: 1;
  }
  .site-title {
    background: linear-gradient(135deg, var(--color-red), var(--color-purple), var(--color-blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .site-title:hover {
    -webkit-text-fill-color: transparent;
    text-decoration: none;
  }
</style>

<script is:inline>
  // Apply saved theme or system preference on load
  const savedTheme = localStorage.getItem('theme');
  const systemPrefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;

  function applyTheme(dark) {
    document.documentElement.classList.toggle('dark', dark);
    localStorage.setItem('theme', dark ? 'dark' : 'light');
    const btn = document.getElementById('theme-toggle');
    if (btn) btn.textContent = dark ? '☀️' : '🌙';
  }

  if (savedTheme === 'dark') {
    applyTheme(true);
  } else if (savedTheme === 'light') {
    applyTheme(false);
  } else {
    applyTheme(systemPrefersDark);
  }

  document.addEventListener('click', function(e) {
    if (e.target.closest('#theme-toggle')) {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      e.target.textContent = isDark ? '☀️' : '🌙';
    }
  });
</script>
