---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Generate slug from post.id (filename without extension)
const postsWithSlug = posts.map((post) => ({
  ...post,
  slug: post.id.replace(/\.mdx?$/, ''),
}));
---

<BaseLayout title="Blog — Kiefer Taylor Land" description="Thoughts on software testing, cybersecurity, AI/LLM security, music, and tech.">
  <Header />
  <main id="content" class="page-main">
    <header class="page-header">
      <p class="page-kicker">Field Notes</p>
      <h1>Blog</h1>
      <p class="page-description">
        Thoughts on software testing, cybersecurity, AI/LLM security, music, and tech.
      </p>
    </header>
    {posts.length === 0 ? (
      <p class="empty-state">
        No posts yet. Stay tuned — something's coming.
      </p>
    ) : (
      <div class="post-list">
        {postsWithSlug.map((post) => (
          <PostCard
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            slug={post.slug}
          />
        ))}
      </div>
    )}
  </main>
  <Footer />
</BaseLayout>
