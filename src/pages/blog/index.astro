---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PostCard from '../../components/PostCard.astro';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Blog — Kiefer Taylor Land" description="Thoughts on software testing, cybersecurity, AI/LLM security, music, and tech.">
  <Header />
  <main>
    <h1>Blog</h1>
    {posts.length === 0 ? (
      <p style="color: var(--color-text-muted); margin-top: 2rem;">
        No posts yet. Stay tuned — something's coming.
      </p>
    ) : (
      <div style="display: flex; flex-direction: column; gap: 2rem; margin-top: 2rem;">
        {posts.map((post) => (
          <PostCard
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            slug={post.slug}
          />
        ))}
      </div>
    )}
  </main>
  <Footer />
</BaseLayout>
