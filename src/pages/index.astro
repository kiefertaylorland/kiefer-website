---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Kiefer Taylor Land — Software Tester & Cybersecurity Professional">
  <Header />
  <main>
    <div class="text-center mt-lg">
      <h1>Kiefer Taylor Land</h1>
      <p style="font-size: 1.25rem; color: var(--color-text-muted); margin-bottom: 1.5rem;">
        Software Tester · Cybersecurity Professional · Musician
      </p>
      <p style="max-width: 560px; margin: 0 auto 2rem;">
        I test AI and software systems for a living, play guitar for fun, and believe 
        the best code is the code you don't write. Currently exploring AI/LLM security 
        and breaking things.
      </p>
      <p>
        <a href="/blog/" style="margin-right: 1rem;">Read the Blog →</a>
        <a href="/about/">Learn About Me →</a>
      </p>
    </div>
  </main>
  <Footer />
</BaseLayout>
