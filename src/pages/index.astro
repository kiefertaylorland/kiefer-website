---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Kiefer Taylor Land — Software Tester & Cybersecurity Professional">
  <Header />
  <main>
    <div class="hero">
      <h1 class="hero-title">Kiefer Taylor Land</h1>
      <p class="hero-subtitle">
        Software Tester · Cybersecurity Professional · Musician
      </p>
      <p class="hero-bio">
        I test AI and software systems for a living, play guitar for fun, and believe
        the best code is the code you don't write. Currently exploring AI/LLM security
        and building things that matter.
      </p>
      <div class="hero-links">
        <a href="/blog/" class="btn btn-primary">Read the Blog →</a>
        <a href="/about/" class="btn btn-secondary">Learn About Me →</a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
